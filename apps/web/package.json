  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.7.0",
    "@repo/ui": "workspace:*",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "mongodb": "^7.1.1",
    "next": "16.2.0",
    "next-auth": "^4.24.14",
    "nodemailer": "^8.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.74.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "postcss": "^8.5.9",
    "prisma": "^6.7.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.2",
    "vitest": "^4.1.5"
  }
