    "db:products:import:legacy": "node ./scripts/products-import.mjs",
    "db:products:replace": "pnpm run db:products:reset && pnpm run db:products:import",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
